# Miljøvariabler for Argus — Bitbucket Audit
# Kopier denne filen til .env og fyll inn verdiene dine.
# .env skal IKKE sjekkes inn i versjonskontroll.

# Base-URL til Bitbucket Server/Data Center (påkrevd)
BITBUCKET_URL=https://bitbucket.eksempel.no

# Antall samtidige repo-sjekker (valgfri, default 5)
CONCURRENCY=5

# Maks antall repos å sjekke per kjøring (valgfri, 0 = ingen grense)
# Nyttig under testing for å begrense scope
MAX_REPOS=20

# Begrens kjøringen til ett Bitbucket-prosjekt (valgfri)
# Kan også oppgis som CLI-argument: node index.js PROSJEKTNØKKEL
# PROJECT_KEY=MITT_PROSJEKT

# Minimum alvorlighetsgrad for OSV sårbarhetsskanning (valgfri, default HIGH)
# Gyldige verdier: CRITICAL, HIGH, MEDIUM, LOW, NONE
# Sårbarheter på valgt nivå og høyere rapporteres.
# OSV_SEVERITY_THRESHOLD=HIGH

# ---------------------------------------------------------------------------
# Offline OSV (lokal SQLite-database i stedet for api.osv.dev)
# ---------------------------------------------------------------------------

# Aktiver offline-modus: true = bruk lokal db, false/fraværende = bruk api.osv.dev
# OSV_OFFLINE=true

# Økosystemer å laste ned (kommaseparert). Standard: npm,PyPI,Maven,Go,crates.io,NuGet,RubyGems
# OSV_LOCAL_ECOSYSTEMS=npm,Maven

# Maks alder (timer) før lokal db re-synkroniseres. Standard: 24
# OSV_LOCAL_MAX_AGE_HOURS=24

# Katalog for lokal OSV-database og cache (valgfri, default osv-local/data/)
# OSV_LOCAL_DATA_DIR=~/.config/argus/osv
